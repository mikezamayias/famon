{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "dart",
  "include-component-in-tag": false,
  "separate-pull-requests": false,
  "pull-request-header": "Automated release PR — generated by release-please from Conventional Commits since the last tag.",
  "last-release-sha": "86e1bd551237f5e3ec82b8d8bdee217279f69ae0",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "famon",
      "components": ["famon", "famon_core"]
    }
  ],
  "packages": {
    ".": {
      "package-name": "famon",
      "component": "famon",
      "extra-files": [
        "lib/src/version.dart",
        {
          "type": "generic",
          "path": "pubspec.yaml"
        }
      ]
    },
    "packages/famon_core": {
      "package-name": "famon_core",
      "component": "famon_core"
    }
  }
}
